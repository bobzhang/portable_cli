///|
/// Entry point that points users at the portable CLI examples.
/// Run individual commands with `moon run --target wasm cmd/<name>`.
fn main {
  println(
    "portable_cli commands: cmd/cow, cmd/datascout, cmd/htmlfmt, cmd/jqlet, cmd/pdfskill, cmd/repopack, cmd/secretscan, cmd/tree, cmd/pulse",
  )
}
